{
  "expo": {
    "name": "Attenary",
    "slug": "attenary",
    "scheme": "attenary",
    "version": "3.23.7",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f1eedf"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "newArchEnabled": false,
      "jsEngine": "hermes",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f1eedf"
      },
      "package": "com.oryno.attenary",
      "permissions": [
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-file-system",
        {
          "android": {
            "writeExternalStorage": true
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-image-picker",
      "expo-secure-store",
      "expo-sharing",
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "700790dd-4cbf-4ffd-a7c3-5d959ffb5ddf"
      }
    },
    "owner": "orynos-organization"
  }
}
